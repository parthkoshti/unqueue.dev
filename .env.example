# App environment (api + platform). Managed in Doppler.
#
#   doppler login
#   pnpm doppler:setup
#   doppler secrets set KEY value
#
# Or bulk upload:
#   doppler secrets upload .env.example --format env

# --- Database ---
# Connect via PgBouncer (not Postgres directly).
DATABASE_URL=postgresql://unqueue:password@pgbouncer:5432/unqueue

# --- Redis ---
# Used by the API for queue discovery cache and the demo worker.
REDIS_URL=redis://:password@redis:6379

# --- Better Auth ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Share auth cookies across subdomains in prod (e.g. .unqueue.dev).
COOKIE_DOMAIN=localhost

# --- URLs ---
PLATFORM_URL=http://localhost:5174
WEB_URL=

# --- Platform (Vite) ---
# API URL the browser calls for /rpc, auth, and Socket.IO.
# Dev default: http://localhost:3001 (can omit)
# Prod: required — e.g. https://api.unqueue.dev
VITE_API_URL=

# --- Encryption ---
# JSON array; highest keyId is active. Generate with:
# node -e "console.log(JSON.stringify([{keyId:1,key:require('crypto').randomBytes(32).toString('base64')}]))"
ENCRYPTION_KEYS=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@unqueue.dev

# --- API ---
PORT=3001
NODE_ENV=development

# --- Notifications (optional) ---
DISCORD_NOTIFICATION_URL=
