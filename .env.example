# App environment (server + platform). Managed in Doppler.
#
#   doppler login
#   pnpm doppler:setup
#   doppler secrets set KEY value
#
# Or bulk upload:
#   doppler secrets upload .env.example --format env

# --- Database ---
# Connect via PgBouncer (not Postgres directly).
DATABASE_URL=postgresql://unqueue:password@pgbouncer:5432/unqueue

# --- Redis ---
REDIS_URL=redis://:password@redis:6379

# --- Better Auth ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Share auth cookies across subdomains in prod (e.g. .parthk.dev).
COOKIE_DOMAIN=localhost

# --- URLs ---
PLATFORM_URL=http://localhost:5174
API_URL=http://localhost:3001

# --- Platform (Vite) ---
# Server URL the browser calls for /api, /rpc, and Socket.IO.
# Local dev: omit to use http://localhost:3001
# Prod example:
#   VITE_API_URL=https://unqueueserver.parthk.dev
#   PLATFORM_URL=https://unqueue.parthk.dev
#   BETTER_AUTH_URL=https://unqueueserver.parthk.dev
#   API_URL=https://unqueueserver.parthk.dev
#   COOKIE_DOMAIN=.parthk.dev
VITE_API_URL=

# --- Encryption ---
# JSON array; highest keyId is active. Generate with:
# node -e "console.log(JSON.stringify([{keyId:1,key:require('crypto').randomBytes(32).toString('base64')}]))"
ENCRYPTION_KEYS=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@unqueue.dev

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Demo worker (optional; BullMQ Redis, not app Redis) ---
BULLMQ_REDIS_URL=redis://localhost:6379
