---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout
  title="Writing — unqueue"
  description="Queue infrastructure, BullMQ internals, and notes on building unqueue."
  canonical="https://unqueue.dev/blog"
>
  <div class="mx-auto max-w-4xl px-4 pb-32 pt-32 sm:px-6">
    <div class="mb-16 border-b border-border pb-12">
      <p class="mb-5 font-mono text-xs uppercase tracking-widest text-muted-foreground/60">
        unqueue / writing
      </p>
      <h1 class="mb-4 font-mono text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
        The queue engineering blog.
      </h1>
      <p class="max-w-lg text-base leading-relaxed text-muted-foreground">
        Deep dives into BullMQ, Redis queue internals, production war stories, and how unqueue is built.
      </p>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-muted-foreground">No posts yet.</p>
      ) : (
        <ol class="space-y-0">
          {posts.map((post, i) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group grid grid-cols-[3rem_1fr] gap-6 border-b border-border/50 py-10 sm:grid-cols-[4rem_1fr] sm:gap-10"
              >
                <div class="pt-1">
                  <span class="font-mono text-2xl font-bold tabular-nums text-border transition-colors group-hover:text-primary/30 sm:text-3xl">
                    {String(posts.length - i).padStart(2, "0")}
                  </span>
                </div>

                <div class="min-w-0">
                  <div class="mb-3 flex flex-wrap items-center gap-2">
                    <time class="font-mono text-xs text-muted-foreground">
                      {formatDate(post.data.date)}
                    </time>
                    {
                      post.data.tags && post.data.tags.length > 0 && (
                        <>
                          <span class="text-border/60" aria-hidden="true">
                            ·
                          </span>
                          {post.data.tags.slice(0, 3).map((tag) => (
                            <span class="font-mono text-xs text-muted-foreground/60">
                              {tag}
                            </span>
                          ))}
                        </>
                      )
                    }
                  </div>

                  <h2 class="mb-3 text-xl font-semibold leading-snug tracking-tight text-foreground transition-colors group-hover:text-primary sm:text-2xl">
                    {post.data.title}
                  </h2>

                  <p class="text-sm leading-relaxed text-muted-foreground sm:text-base">
                    {post.data.description}
                  </p>

                  {
                    post.data.author && (
                      <p class="mt-4 text-xs text-muted-foreground/50">{post.data.author}</p>
                    )
                  }
                </div>
              </a>
            </li>
          ))}
        </ol>
      )
    }
  </div>
</BaseLayout>
