{
  "name": "@unqueue/orpc",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "default": "./dist/router.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@orpc/client": "^1.14.5",
    "@orpc/experimental-pino": "^1.14.5",
    "@orpc/server": "1.14.5",
    "@orpc/tanstack-query": "^1.14.5",
    "@tanstack/react-query": "^5.100.14",
    "@unqueue/db": "workspace:*",
    "@unqueue/logger": "workspace:*",
    "@unqueue/services": "workspace:*",
    "@unqueue/shared": "workspace:*",
    "@unqueue/validators": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@unqueue/config": "workspace:*",
    "react": "^19.2.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
