# Infrastructure secrets for docker-compose.infra.yml (Doppler).
#
# Upload to Doppler (one config per environment, e.g. dev / prd):
#   doppler secrets upload .env.infra.example --format env -p unstall -c dev
#
# Create a Doppler service token for that config and set DOPPLER_TOKEN in Dokploy.
# Deploy as a separate compose stack from docker-compose.yml.

# --- Postgres ---
POSTGRES_USER=unstall
POSTGRES_PASSWORD=
POSTGRES_DB=unstall

# --- PgBouncer (internal URL to postgres; postgres is not exposed) ---
DATABASE_URL=postgresql://unstall:PASSWORD@postgres:5432/unstall
MAX_CLIENT_CONN=200
DEFAULT_POOL_SIZE=20

# --- Optional host port overrides (set in Dokploy env, not required in Doppler) ---
# PGBOUNCER_PORT=6432
# REDIS_PORT=6379

# --- App URLs (set in Doppler / .env.example after infra is up) ---
# In-network (app + infra on same Dokploy network):
#   DATABASE_URL=postgresql://unstall:PASSWORD@pgbouncer:5432/unstall
#   REDIS_URL=redis://redis:6379
#
# External / host access:
#   DATABASE_URL=postgresql://unstall:PASSWORD@your-host:6432/unstall
#   REDIS_URL=redis://your-host:6379
