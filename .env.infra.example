# Infrastructure stack (docker-compose.infra.yml).
# Copy these into Dokploy compose environment (separate stack from the app).

# --- Postgres ---
POSTGRES_USER=unstall
POSTGRES_PASSWORD=
POSTGRES_DB=unstall

# --- PgBouncer (only Postgres entrypoint; postgres is internal) ---
PGBOUNCER_PORT=6432
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# --- Redis ---
REDIS_PASSWORD=
REDIS_PORT=6379

# --- App URLs (set in Doppler / .env.example after infra is up) ---
# In-network (app + infra on same Dokploy network):
#   DATABASE_URL=postgresql://unstall:PASSWORD@pgbouncer:5432/unstall
#   REDIS_URL=redis://:REDIS_PASSWORD@redis:6379
#
# External / host access:
#   DATABASE_URL=postgresql://unstall:PASSWORD@your-host:6432/unstall
#   REDIS_URL=redis://:REDIS_PASSWORD@your-host:6379
